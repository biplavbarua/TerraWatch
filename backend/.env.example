# ─── Database ──────────────────────────────────────────────────────────────
# Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Neon:     postgresql://[user]:[password]@[host]/[db]?sslmode=require
DATABASE_URL=postgresql://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# ─── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── App Config ────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS (use * for open dev)
CORS_ORIGINS=*

# How often to poll EONET for new/updated events (minutes)
POLL_INTERVAL_MINUTES=15

# How many years of historical data to backfill on first boot
BACKFILL_YEARS=5

# Set to "true" to skip backfill (faster cold starts after initial run)
SKIP_BACKFILL=false
