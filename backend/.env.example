# TerraWatch Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# In production (Railway), set these as environment variables in the dashboard.

# ── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL session-pooler connection string
# Format: postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ── AI / LLM ────────────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai) — used for Gemini 2.5 Flash tool calling
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Legacy alias — accepted for backward compatibility but OPENROUTER_API_KEY takes precedence
# GEMINI_API_KEY=sk-or-v1-your-openrouter-key-here

# ── Security ─────────────────────────────────────────────────────────────────
# Secret token for the admin-only POST /api/ingest/trigger endpoint.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=change-me-to-a-long-random-string

# ── CORS ────────────────────────────────────────────────────────────────────
# Origins allowed to call the API.
# Development:  CORS_ORIGINS=*
# Production:   CORS_ORIGINS=https://terrawatch.biplavbarua.dev
CORS_ORIGINS=*

# ── Scheduler ───────────────────────────────────────────────────────────────
# How often to poll NASA EONET for new open events (minutes)
POLL_INTERVAL_MINUTES=15

# How many years of historical EONET data to backfill on first run
BACKFILL_YEARS=3

# Set to true to skip the historical backfill on startup (useful for quick restarts)
SKIP_BACKFILL=false
